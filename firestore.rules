rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isAdmin() { return signedIn() && request.auth.uid == "31ZskJ12hdNhy5D5lwP6dPB5Kw92"; }

    // ✅ الأكثر أمانًا للاستخدام الفردي (مالك واحد):
    // كل القراءة والكتابة للأدمن فقط.
    match /users/{userId} {
      allow read, write: if isAdmin();
    }

    match /cashboxes/{cashboxId} {
      allow read, write: if isAdmin();

      match /transactions/{txId} {
        allow read, write: if isAdmin();
      }

      match /meta/{docId} {
        allow read, write: if isAdmin();
      }
    }

    match /cheques/{chequeId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
